<Project Sdk="Microsoft.VisualStudio.JavaScript.Sdk/1.0.1184077">
  <PropertyGroup>
    <!-- Comando executado quando o projeto é iniciado pelo Visual Studio -->
    <StartupCommand>npm start</StartupCommand>
    <!-- Não roda "npm run build" no build da solution (o host .NET usa o ng serve em dev) -->
    <ShouldRunBuildScript>false</ShouldRunBuildScript>
    <BuildOutputFolder>$(MSBuildProjectDirectory)\dist</BuildOutputFolder>
    <JavaScriptTestRoot>src\</JavaScriptTestRoot>
    <JavaScriptTestFramework>Jasmine</JavaScriptTestFramework>
  </PropertyGroup>
</Project>
